PORT=4000
AGENT_TOKEN=change-me-with-a-strong-token

# Ruta raiz del proyecto TestQA (donde esta el pom.xml)
RUNNER_PATH=C:\Users\your.user\Desktop\Claro\TestQA

# Carpeta donde viven los .feature
FEATURES_DIR=C:\Users\your.user\Desktop\Claro\TestQA\src\test\resources\features

# Carpeta de reportes generados por Karate
REPORTS_DIR=C:\Users\your.user\Desktop\Claro\TestQA\target\karate-reports

# Ambiente default (desa | prod)
DEFAULT_ENV=desa

# Origenes permitidos (frontend + backend de QATestUI)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

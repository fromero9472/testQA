# ── Configuración del Runner Agent ─────────────────────────────────
PORT=4000
AGENT_TOKEN=local-dev-token

# Ruta raíz del proyecto TestQA (donde está el pom.xml)
RUNNER_PATH=C:\Users\federico.romero\Desktop\Claro\KarateTest\TestQA

# Carpeta donde viven los .feature
FEATURES_DIR=C:\Users\federico.romero\Desktop\Claro\KarateTest\TestQA\src\test\resources\features

# Carpeta de reportes generados por Karate
REPORTS_DIR=C:\Users\federico.romero\Desktop\Claro\KarateTest\TestQA\target\karate-reports

# Ambiente default (desa | prod)
DEFAULT_ENV=desa

# Orígenes permitidos (frontend + backend de QATestUI)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Fuerza Java/Maven para las ejecuciones iniciadas desde la UI.
# Karate 1.4.1 + Graal funciona estable en Java 17-21.
RUNNER_JAVA_HOME=C:\Program Files\Amazon Corretto\jdk21.0.10_7
RUNNER_MAVEN_HOME=C:\Users\federico.romero\Desktop\Claro\apache-maven-3.9.12
MAVEN_CMD=C:\Users\federico.romero\Desktop\Claro\apache-maven-3.9.12\bin\mvn.cmd

